# Copy to .env and fill local values. Do not commit .env.

TZ=UTC
BACKEND_PORT=8010

# TRMNL/backend behavior
PUBLIC_BASE_URL=https://anki.example.com
TRMNL_PRIVATE_PATH=/trmnl/change-me-long-random-token/random
TRMNL_ANKI_CADENCE_MINUTES=30
TRMNL_ANKI_CACHE_PATH=/data/cache/current-card.json
TRMNL_ANKI_BACKGROUND_SYNC_ENABLED=true
TRMNL_ANKI_REFRESH_ON_STARTUP=true
TRMNL_ANKI_EXPOSE_API_DOCS=false

# AnkiConnect/backend behavior
ANKI_LAUNCHER_URL=https://github.com/ankitects/anki/releases/download/25.09/anki-launcher-25.09-linux.tar.zst
ANKI_LAUNCHER_SHA256=97cbddae74e44944360cac89bbdda06af7cf080a4dc1012dd6dc63952bbbb029
ANKICONNECT_REF=23.10.29.0
ANKI_PROFILE=User 1
ANKICONNECT_API_KEY=
TRMNL_ANKI_ANKICONNECT_URL=http://172.28.0.10:8765
TRMNL_ANKI_ANKICONNECT_TIMEOUT_SECONDS=10
TRMNL_ANKI_ANKICONNECT_SYNC_TIMEOUT_SECONDS=120
TRMNL_ANKI_DECK_NAME=Core 2000
TRMNL_ANKI_CARD_QUERY=deck:"Core 2000" (is:learn or is:review)
TRMNL_ANKI_FALLBACK_QUERY=deck:"Core 2000" (is:learn or is:review)
TRMNL_ANKI_MIN_CARDS=1
TRMNL_ANKI_MAX_CARDS=250
TRMNL_ANKI_MAX_QUERY_LENGTH=500
TRMNL_ANKI_MAX_CACHED_QUERIES=25
TRMNL_ANKI_REFRESH_CONCURRENCY=1
TRMNL_ANKI_SYNC_INTERVAL_SECONDS=3600
TRMNL_ANKI_SYNC_RETRY_INTERVAL_SECONDS=60

# noVNC/Anki bootstrap. Use a strong local/admin password before exposing port 3000.
KASMVNC_USER=admin
KASMVNC_PASSWORD=
KASMVNC_PORT=3000

# Reverse proxy should own TLS, rate limits, access logs, and any auth headers.
TRUSTED_PROXY_CIDRS=127.0.0.1/32
