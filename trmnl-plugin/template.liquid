<div class="anki-board {% if stale %}is-stale{% endif %} {% if status != 'ok' %}is-muted{% endif %}">
  {% if status == 'ok' and card %}
    <header class="topline">
      <span>Anki / Core 2000</span>
      <span>{{ cadence_minutes | default: 30 }} min</span>
    </header>

    <main class="word-panel">
      <section class="glyph-lockup">
        <div class="ruby-line">
          {% if card.furigana_html %}
            {{ card.furigana_html }}
          {% else %}
            <ruby>{{ card.headword }}<rt>{{ card.reading }}</rt></ruby>
          {% endif %}
        </div>
        <div class="meaning">{{ card.meaning }}</div>
      </section>

      <section class="sentence-card">
        <p class="jp">{{ card.sentence }}</p>
        <p class="en">{{ card.sentence_translation }}</p>
      </section>
    </main>

    <footer class="status-strip">
      <span>slot {{ slot_id }}</span>
      <span>{% if stale %}stale{% else %}fresh{% endif %}</span>
      <span>sync {{ last_sync_at | default: 'never' }}</span>
    </footer>
  {% elsif status == 'empty' %}
    <main class="state-panel">
      <div class="state-kicker">Anki / Core 2000</div>
      <h1>No cards cached yet</h1>
      <p>Backend is waiting for AnkiConnect data. Keep this endpoint cached; do not expose AnkiConnect.</p>
    </main>
  {% else %}
    <main class="state-panel">
      <div class="state-kicker">Anki / paused</div>
      <h1>Card feed unavailable</h1>
      <p>{{ error | default: last_sync_error | default: 'The cached endpoint did not return a usable card.' }}</p>
    </main>
  {% endif %}
</div>
